  "npcs": [
    {
      "id": "silent_brother",
      "name": "The Silent Brother",
      "title": "Eighty-Seventh Keeper of the Coal",
      "glyph": "🧘",
      "zone": "chapel",
      "x": 135, "y": 400,
      "visible": true,
      "condition": null,
      "interactions": [
        {
          "trigger": "tendFire",
          "response": "nods once",
          "dialogue": "He does not speak. He has never spoken. But his nod carries weight."
        },
        {
          "trigger": "firstSpeak",
          "condition": { "ice": 60, "faith": 40, "random": 0.3 },
          "response": "speaks one word",
          "dialogue": "\"Threshold.\" One word. The eighty-seventh keeper speaks. Then silence resumes.",
          "effect": { "faith": 15, "morale": 5 }
        }
      ]
    },
    {
      "id": "rabbit",
      "name": "The Rabbit",
      "title": "Watcher at the Edge",
      "glyph": "🐇",
      "zone": "kings_chambers",
      "x": 665, "y": 395,
      "visible": false,
      "condition": "rabbitAppeared",
      "movement": {
        "type": "wander",
        "zones": ["kings_chambers", "courtyard", "court", "wild_wood"],
        "frequency": "seasonal"
      },
      "interactions": [
        {
          "trigger": "waitInChambers",
          "condition": "rabbitAppeared",
          "dialogue": "The Rabbit sits on the empty bed. He looks at the pillow, then at you. 'Not yet,' his silence says. He leaves.",
          "effect": { "faith": 8, "rabbitAppeared": false }
        },
        {
          "trigger": "seekOmen",
          "condition": "rabbitAppeared",
          "dialogue": "The Rabbit appears on the battlement. He looks at the glyph. He looks at you. He vanishes.",
          "effect": { "rabbitAppeared": false }
        }
      ]
    },
    {
      "id": "nokomis",
      "name": "Nokomis",
      "title": "The Whisper",
      "glyph": "👁️",
      "zone": null,
      "x": 0, "y": 0,
      "visible": false,
      "condition": "nokomisAppears",
      "movement": {
        "type": "appear",
        "zones": ["battlements", "wild_wood", "chapel", "court"],
        "frequency": "rare",
        "duration": "moment"
      },
      "interactions": [
        {
          "trigger": "appear",
          "dialogue": "Nokomis whispers from nowhere: \"{random_saying}\""
        }
      ]
    }
  ],

