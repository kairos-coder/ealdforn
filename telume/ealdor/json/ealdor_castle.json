      "w": 800, "h": 35,
      "color": "#3d362f",
      "clickable": true,
      "zone": "battlements",
      "icon": "🏰",
      "description": "The wind bites hardest here. From the Threshold Wall, you can see what comes across the fjord — ships, ice, or nothing at all. The watch never sleeps.",
      "actionName": "Scan the Horizon",
      "action": "seekOmen",
      "actionCost": 1,
      "features": [
        { "type": "watchtower", "x": 700, "y": 95, "w": 30, "h": 45 },
        { "type": "watchtower", "x": 70, "y": 95, "w": 30, "h": 45 },
        { "type": "brazier", "x": 400, "y": 108, "lit": true, "color": "#c44f1c" }
      ]
    },
    {
      "id": "gatehouse",
      "name": "The Open Gate",
      "ealdorName": "Gatehouse",
      "type": "building",
      "x": 340, "y": 118,
      "w": 120, "h": 58,
      "color": "#5c4f42",
      "roof": "peaked",
      "roofColor": "#3d362f",
      "roofHeight": 28,
      "clickable": true,
      "zone": "gatehouse",
      "icon": "🚪",
      "description": "The portcullis has not been lowered since the council took the castle. Envoys from Tsarnigrad, Kichigamswak, and Haldor arrive here. The gate remains open — a statement.",
      "actionName": "Receive Envoys",
      "action": "tradeWithKingdom",
      "actionCost": 1,
      "features": [
        { "type": "door", "x": 380, "y": 148, "w": 40, "h": 28, "open": true },
        { "type": "portcullis", "x": 360, "y": 118, "w": 80, "h": 10, "raised": true },
        { "type": "banner", "x": 395, "y": 100, "text": "𐤃", "color": "#b8860b" }
      ],
      "interior": {
        "visible": true,
        "depth": 20,
        "color": "#2a2018",
        "features": [
          { "type": "guard_post", "x": 360, "y": 155 },
          { "type": "guard_post", "x": 420, "y": 155 }
        ]
      }
    },
    {
      "id": "great_hall",
      "name": "The Thing-Stead",
      "ealdorName": "Great Hall",
      "type": "building",
      "x": 70, "y": 210,
      "w": 180, "h": 130,
      "color": "#5c4f42",
      "roof": "vaulted",
      "roofColor": "#4a3a2f",
      "roofHeight": 35,
      "clickable": true,
      "zone": "greatHall",
      "icon": "🪨",
      "description": "No throne. A circle of twelve stones surrounds a fire pit. Charcoal tally marks cover the walls — every vote ever taken, some centuries old. The Thing governs here.",
      "actionName": "Convene the Thing",
      "action": "conveneThing",
      "actionCost": 2,
      "features": [
        { "type": "door", "x": 140, "y": 312, "w": 35, "h": 28, "open": true },
        { "type": "window", "x": 100, "y": 225, "w": 16, "h": 20, "lit": true, "color": "#daa520" },
        { "type": "window", "x": 200, "y": 225, "w": 16, "h": 20, "lit": true, "color": "#daa520" },
        { "type": "smoke", "x": 160, "y": 195, "visible": true, "color": "#8b7d6b" }
      ],
      "interior": {
        "visible": true,
        "depth": 40,
        "color": "#2a2018",
        "features": [
          { "type": "round_table", "x": 140, "y": 260, "r": 25 },
          { "type": "fire_pit", "x": 160, "y": 280, "r": 8, "lit": true, "color": "#c44f1c" },
          { "type": "council_stone", "x": 115, "y": 245, "r": 5 },
          { "type": "council_stone", "x": 165, "y": 245, "r": 5 },
          { "type": "tally_marks", "x": 90, "y": 230, "w": 50, "h": 40 }
        ]
      }
    },
    {
      "id": "court",
      "name": "The Empty Court",
      "ealdorName": "Court",
      "type": "building",
      "x": 550, "y": 210,
      "w": 180, "h": 130,
      "color": "#5c4f42",
      "roof": "domed",
      "roofColor": "#4a3a2f",
      "roofHeight": 40,
      "clickable": true,
      "zone": "court",
      "icon": "👑",
      "description": "A throne sits against the far wall. It is clean. It is empty. The council refuses to fill it. Glyphs are carved into the stone floor — some ancient, some newly cut. The seventh tablet waits.",
      "actionName": "Study the Glyphs",
      "action": "studyGlyphs",
      "actionCost": 1,
      "features": [
        { "type": "door", "x": 620, "y": 312, "w": 35, "h": 28, "open": true },
        { "type": "window", "x": 580, "y": 225, "w": 16, "h": 20, "lit": false },
        { "type": "window", "x": 680, "y": 225, "w": 16, "h": 20, "lit": false },
        { "type": "dome_oculus", "x": 640, "y": 190, "r": 12, "color": "#6b6b7a" }
      ],
      "interior": {
        "visible": true,
        "depth": 40,
        "color": "#1a1818",
        "features": [
          { "type": "empty_throne", "x": 640, "y": 250, "w": 30, "h": 50, "color": "#b8860b" },
          { "type": "glyph_floor", "x": 580, "y": 280, "w": 120, "h": 60, "glyphs": ["𐤃","𐤀","𐤕","𐤔","𐤐","𐤌","𐤇"] },
          { "type": "tablet_stand", "x": 610, "y": 265, "w": 15, "h": 25, "tabletCount": 6 },
          { "type": "candle", "x": 590, "y": 240, "lit": true },
          { "type": "candle", "x": 690, "y": 240, "lit": true }
        ]
      }
    },
    {
      "id": "chapel",
      "name": "The Coal Chapel",
      "ealdorName": "Chapel",
      "type": "building",
      "x": 70, "y": 365,
      "w": 160, "h": 80,
      "color": "#4a3a2f",
      "roof": "steeple",
      "roofColor": "#3d3028",
      "roofHeight": 50,
      "clickable": true,
      "zone": "chapel",
      "icon": "🔥",
      "description": "The Ātravan Coal burns in an iron brazier. It has never gone out. The Silent Brother — eighty-seventh of his line — tends it. He has never spoken. The fire has never failed.",
      "actionName": "Tend the Fire",
      "action": "tendFire",
      "actionCost": 1,
      "features": [
        { "type": "door", "x": 130, "y": 417, "w": 30, "h": 28, "open": true },
        { "type": "steeple_cross", "x": 150, "y": 320, "w": 8, "h": 20 },
        { "type": "window", "x": 100, "y": 380, "w": 16, "h": 24, "lit": true, "color": "#c44f1c" },
        { "type": "window", "x": 180, "y": 380, "w": 16, "h": 24, "lit": true, "color": "#c44f1c" },
        { "type": "glow", "x": 150, "y": 400, "r": 50, "color": "#c44f1c", "pulse": true }
      ],
      "interior": {
        "visible": true,
        "depth": 30,
        "color": "#1a1410",
        "features": [
          { "type": "brazier", "x": 150, "y": 390, "r": 12, "lit": true, "color": "#c44f1c", "pulse": true },
          { "type": "npc_spot", "x": 135, "y": 400, "npc": "silent_brother" },
          { "type": "wood_stack", "x": 95, "y": 410, "w": 20, "h": 15 }
        ]
      }
    },
    {
      "id": "kings_chambers",
      "name": "The Unoccupied Room",
      "ealdorName": "King's Chambers",
      "type": "building",
      "x": 570, "y": 365,
      "w": 160, "h": 80,
      "color": "#5c4f42",
      "roof": "gabled",
      "roofColor": "#4a3a2f",
      "roofHeight": 22,
      "clickable": true,
      "zone": "kingsChambers",
      "icon": "🛏️",
      "description": "The bed is made. A fire burns in the grate — the servants keep it lit, though no one sleeps here. The window looks south, toward the wild wood. Sometimes the Rabbit sits on the pillow.",
      "actionName": "Wait and Watch",
      "action": "waitInChambers",
      "actionCost": 1,
      "features": [
        { "type": "door", "x": 630, "y": 417, "w": 30, "h": 28, "open": false },
        { "type": "window", "x": 600, "y": 380, "w": 16, "h": 20, "lit": true, "color": "#daa520" },
        { "type": "window", "x": 700, "y": 380, "w": 16, "h": 20, "lit": true, "color": "#daa520" },
        { "type": "chimney", "x": 690, "y": 355, "w": 18, "h": 25 },
        { "type": "smoke", "x": 699, "y": 350, "visible": true }
      ],
