{
  "id": "ealdor_castle",
  "name": "The Castle of Ealdor",
  "description": "A castle built for a king, held by a council that refuses to crown one. The fjord freezes to the north. The wild wood watches from the south. The Ātravan Coal burns in the chapel. The throne sits empty.",
  "version": "1.0.0",
  "width": 800,
  "height": 520,
  
  "sky": {
    "type": "gradient",
    "top": "#1a1820",
    "mid": "#3a4050",
