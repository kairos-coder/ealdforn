        "visible": true,
        "depth": 30,
        "color": "#2a2018",
        "features": [
          { "type": "bed", "x": 680, "y": 390, "w": 35, "h": 22, "empty": true },
          { "type": "fireplace", "x": 610, "y": 385, "w": 20, "h": 25, "lit": true },
          { "type": "npc_spot", "x": 665, "y": 395, "npc": "rabbit", "condition": "rabbitAppeared" }
        ]
      }
    },
    {
      "id": "courtyard",
      "name": "The People's Yard",
      "ealdorName": "Courtyard",
      "type": "courtyard",
      "x": 280, "y": 230,
      "w": 240, "h": 215,
      "color": "#6b5d4f",
      "clickable": true,
      "zone": "courtyard",
      "icon": "🌾",
      "description": "Markets, workshops, the granary tower. Smoke rises from the forge. Grain sacks lean against the tower. The people of Ealdor work here — the castle's beating heart.",
      "actionName": "Manage Resources",
      "action": "manageResources",
      "actionCost": 1,
      "features": [
        { "type": "well", "x": 400, "y": 410, "r": 10 },
        { "type": "market_stall", "x": 310, "y": 260, "w": 40, "h": 20, "color": "#8b7d6b" },
        { "type": "market_stall", "x": 450, "y": 265, "w": 40, "h": 20, "color": "#8b7d6b" },
        { "type": "granary_tower", "x": 460, "y": 370, "w": 45, "h": 60, "color": "#5c4f42", "roof": "conical", "fillLevel": 0.6 },
        { "type": "forge", "x": 310, "y": 380, "w": 35, "h": 25, "color": "#4a3a2f", "smoke": true },
        { "type": "woodpile", "x": 340, "y": 430, "w": 30, "h": 12 },
        { "type": "people", "x": 370, "y": 290, "count": 4, "scattered": true }
      ]
    }
